#!/bin/sh
set -eu

real_hermes='@realHermes@'

if [ ! -x "$real_hermes" ]; then
  echo "hermes-shim: $real_hermes not found or not executable" >&2
  exit 127
fi

if [ "$(id -u)" != 0 ]; then
  exec "$real_hermes" "$@"
fi

case "${HERMES_DOCKER_EXEC_AS_ROOT:-}" in
  1|true|TRUE|True|yes|YES|Yes)
    exec "$real_hermes" "$@"
    ;;
esac

export HOME="${HOME:-/home/hermes}"
export HERMES_HOME="${HERMES_HOME:-/data/.hermes}"
exec s6-setuidgid hermes "$real_hermes" "$@"
